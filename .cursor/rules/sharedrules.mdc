{
    int MaxPaymentMethodsPerClient { get; } // 10
    int MaxPageSize { get; } // 100
    TimeSpan RateLimitWindow { get; } // 1 minute
    int MaxPaymentAttemptsPerWindow { get; } // 5
}
```

