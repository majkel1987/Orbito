{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost\\SQLEXPRESS;Database=Orbito_test;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=true"
  },
  "PerformanceSettings": {
    "MonitorThresholdMs": 200,
    "WarningThresholdMs": 500,
    "CriticalThresholdMs": 1000
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Key": "your_jwt_secret_key_here_minimum_32_characters",
    "Issuer": "http://localhost:5211",
    "Audience": "http://localhost:5211"
  },
  "AdminSetup": {
    "Enabled": false
  },
  "Stripe": {
    "SecretKey": "sk_test_your_secret_key_here",
    "PublishableKey": "pk_test_your_publishable_key_here",
    "WebhookSecret": "whsec_your_webhook_secret_here",
    "Environment": "test",
    "Webhook": {
      "EnableSignatureVerification": true,
      "MaxPayloadSize": 1048576,
      "LogPayloads": false,
      "SignatureToleranceSeconds": 300,
      "MaxRetryAttempts": 3,
      "EnableAsyncProcessing": true
    }
  },
  "PaymentRetry": {
    "RetryDelays": ["00:05:00", "00:15:00", "01:00:00", "06:00:00", "24:00:00"],
    "InProgressTimeout": "00:30:00",
    "MaxConcurrency": 10,
    "MaxAttempts": 5,
    "EnablePaymentProcessing": false
  },
  "RateLimiting": {
    "PermitLimit": 100,
    "WindowMinutes": 1,
    "QueueLimit": 10,
    "Reconciliation": {
      "PermitLimit": 5,
      "WindowMinutes": 15,
      "QueueLimit": 2
    }
  },
  "Cors": {
    "AllowedOrigins": ["http://localhost:3000", "http://localhost:5173"]
  },
  "ReconciliationSettings": {
    "MaxReconciliationPeriodDays": 30,
    "MaxHistoricalDataYears": 1,
    "StripeBatchSize": 100,
    "MaxParallelTasks": 5,
    "StripeApiDelayMs": 100,
    "RateLimitBatchSize": 10,
    "DailyRunTime": "02:00",
    "EmailRecipients": ["finance@orbito.com", "admin@orbito.com"],
    "SlackWebhookUrl": null,
    "CriticalDiscrepancyThreshold": 10,
    "EnableAutoResolution": true,
    "OperationTimeoutMinutes": 10
  },
  "MonitoringSettings": {
    "FailureRateThresholdPercent": 20,
    "MaxPendingRetries": 1000,
    "StripeHealthCheckTimeoutSeconds": 5
  },
  "IdempotencySettings": {
    "CacheTtlHours": 24,
    "RedisConnectionString": "localhost:6379",
    "Enabled": true,
    "MaxKeyLength": 100,
    "MinKeyLength": 1,
    "RequireIdempotencyKey": false,
    "LockTimeoutSeconds": 30,
    "UseDistributedLock": true,
    "CacheKeyPrefix": "idempotency:",
    "EnableLogging": true,
    "MaxCachedResponsesPerTenant": 1000,
    "EnableAutoCleanup": true,
    "CleanupIntervalHours": 6
  }
}
