  "agentInstructions": {
    "beforeStarting": [
      "1. Uruchom ./init.sh",
      "2. Przeczytaj claude-progress.txt",
      "3. Sprawdź git log --oneline -10",
      "4. Znajdź w tym pliku pierwszy blok z passes: false",
      "5. Otwórz Frontend_Prompts.md i znajdź sekcję z promptMarker",
      "6. Przeczytaj CAŁY prompt przed rozpoczęciem pracy"
    ],
    "duringWork": [
      "Wykonuj DOKŁADNIE kroki z promptu",
      "Pracuj nad JEDNYM blokiem na raz",
      "Testuj w przeglądarce po każdej zmianie",
      "Rób git commit po znaczących zmianach"
    ],
    "afterCompletion": [
      "1. npm run typecheck && npm run lint",
      "2. Przetestuj ręcznie wszystkie funkcje z bloku",
      "3. Zmień passes: true w tym pliku",
      "4. Dodaj wpis do claude-progress.txt",
      "5. Git commit: feat(scope): description"
    ]
  }
